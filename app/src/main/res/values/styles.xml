<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="PinKeyStyle">
        <item name="android:layout_width">@dimen/pin_key_size</item>
        <item name="android:layout_height">@dimen/pin_key_size</item>
        <item name="android:layout_marginStart">@dimen/pin_key_gap</item>
        <item name="android:layout_marginEnd">@dimen/pin_key_gap</item>
        <item name="android:background">@drawable/pin_key_bg</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">@dimen/pin_key_text_size</item>
        <item name="android:textStyle">normal</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="android:elevation">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:gravity">center</item>
    </style>

</resources>