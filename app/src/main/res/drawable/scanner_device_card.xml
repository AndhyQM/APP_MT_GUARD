<?xml version="1.0" encoding="utf-8"?>

<selector
    xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">

        <shape android:shape="rectangle">

            <solid android:color="#35168CFF" />

            <corners android:radius="15dp" />

            <stroke
                android:width="1dp"
                android:color="@color/accent_light" />

        </shape>

    </item>

    <item>

        <shape android:shape="rectangle">

            <gradient
                android:angle="0"
                android:startColor="#D90B1B30"
                android:endColor="#C9071426" />

            <corners android:radius="15dp" />

            <stroke
                android:width="1dp"
                android:color="#883A6E9F" />

        </shape>

    </item>

</selector>