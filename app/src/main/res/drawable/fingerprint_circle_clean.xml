<?xml version="1.0" encoding="utf-8"?>

<layer-list
    xmlns:android="http://schemas.android.com/apk/res/android">

    <item>

        <shape android:shape="oval">

            <gradient
                android:angle="270"
                android:startColor="#16168CFF"
                android:centerColor="#0B00B4D8"
                android:endColor="#05050B14" />

            <stroke
                android:width="1dp"
                android:color="#8842D8FF" />

        </shape>

    </item>

    <item
        android:left="10dp"
        android:top="10dp"
        android:right="10dp"
        android:bottom="10dp">

        <shape android:shape="oval">

            <solid android:color="@android:color/transparent" />

            <stroke
                android:width="1dp"
                android:color="#3342D8FF" />

        </shape>

    </item>

</layer-list>