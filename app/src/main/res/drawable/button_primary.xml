<?xml version="1.0" encoding="utf-8"?>

<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Deshabilitado -->
    <item android:state_enabled="false">

        <shape android:shape="rectangle">

            <solid android:color="#33455A70" />

            <corners android:radius="15dp" />

        </shape>

    </item>

    <!-- Presionado -->
    <item android:state_pressed="true">

        <layer-list>

            <!-- Resplandor exterior -->
            <item>

                <shape android:shape="rectangle">

                    <gradient
                        android:angle="0"
                        android:startColor="#440096C7"
                        android:centerColor="#44168CFF"
                        android:endColor="#4442D8FF" />

                    <corners android:radius="16dp" />

                </shape>

            </item>

            <!-- Degradado interior -->
            <item
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp">

                <shape android:shape="rectangle">

                    <gradient
                        android:angle="0"
                        android:startColor="#0096C7"
                        android:centerColor="#00B4D8"
                        android:endColor="#168CFF" />

                    <corners android:radius="14dp" />

                    <stroke
                        android:width="1dp"
                        android:color="#6642D8FF" />

                </shape>

            </item>

        </layer-list>

    </item>

    <!-- Estado normal -->
    <item>

        <layer-list>

            <!-- Resplandor exterior -->
            <item>

                <shape android:shape="rectangle">

                    <gradient
                        android:angle="0"
                        android:startColor="#3342D8FF"
                        android:centerColor="#33168CFF"
                        android:endColor="#3300B4D8" />

                    <corners android:radius="16dp" />

                </shape>

            </item>

            <!-- Degradado principal -->
            <item
                android:left="2dp"
                android:top="2dp"
                android:right="2dp"
                android:bottom="2dp">

                <shape android:shape="rectangle">

                    <gradient
                        android:angle="0"
                        android:startColor="#42D8FF"
                        android:centerColor="#00B4D8"
                        android:endColor="#168CFF" />

                    <corners android:radius="14dp" />

                    <stroke
                        android:width="1dp"
                        android:color="#9942D8FF" />

                </shape>

            </item>

        </layer-list>

    </item>

</selector>