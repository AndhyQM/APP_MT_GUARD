<?xml version="1.0" encoding="utf-8"?>

<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <solid android:color="#3022C7C7" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="#FF42D8FF" />
        </shape>
    </item>

    <item>
        <shape android:shape="rectangle">
            <gradient
                android:angle="0"
                android:startColor="#D906303A"
                android:endColor="#C9071426" />
            <corners android:radius="16dp" />
            <stroke
                android:width="1dp"
                android:color="#7750C7CF" />
        </shape>
    </item>

</selector>