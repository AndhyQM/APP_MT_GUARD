<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:padding="20dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="32dp">

        <TextView
            android:id="@+id/btnVolver"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="← Volver"
            android:textSize="16sp"
            android:textColor="@color/accent"
            android:padding="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="CONFIGURACIONES"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:gravity="center" />

        <!-- Espaciador para centrar el título -->
        <View
            android:layout_width="70dp"
            android:layout_height="1dp" />
    </LinearLayout>

    <!-- ═══ SECCIÓN: Número de emergencia ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:padding="20dp"
        android:layout_marginBottom="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="NÚMERO DE EMERGENCIA"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Se enviará un SMS con tu ubicación a este número cuando presiones el botón de alerta."
            android:textSize="13sp"
            android:textColor="@color/text_hint"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etNumero"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Ej: 5551234567"
            android:inputType="phone"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_hint"
            android:background="@drawable/input_bg"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="16dp" />

        <Button
            android:id="@+id/btnGuardar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="GUARDAR NÚMERO"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/bg_primary"
            android:backgroundTint="@color/accent" />

        <TextView
            android:id="@+id/tvEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sin número guardado"
            android:textSize="13sp"
            android:textColor="@color/text_hint"
            android:gravity="center"
            android:layout_marginTop="12dp" />
    </LinearLayout>

    <!-- ═══ SECCIÓN: Info del dispositivo ═══ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/card_bg"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DISPOSITIVO"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:letterSpacing="0.1"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvDeviceInfo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No conectado"
            android:textSize="14sp"
            android:textColor="@color/text_hint" />
    </LinearLayout>

</LinearLayout>