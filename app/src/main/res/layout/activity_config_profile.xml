<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding_h"
        android:paddingTop="@dimen/screen_padding_top"
        android:paddingEnd="@dimen/screen_padding_h"
        android:paddingBottom="@dimen/screen_padding_bottom">

        <!-- ═══ ENCABEZADO ═══ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/header_height">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnBack"
                android:layout_width="@dimen/header_button_size"
                android:layout_height="@dimen/header_button_size"
                android:layout_gravity="start|center_vertical"
                android:background="@android:color/transparent"
                android:contentDescription="Volver"
                android:padding="9dp"
                app:srcCompat="@drawable/ic_back_panel"
                app:tint="@color/accent_light" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:text="CONFIGURAR PERFIL"
                android:textColor="@color/accent_light"
                android:textSize="@dimen/title_text_size"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- ═══ SEPARADOR ═══ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="@color/divider" />

        <!-- ═══ ÍCONO CENTRAL ═══ -->
        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="32dp"
            android:contentDescription="Perfil"
            android:src="@drawable/ic_settings_profile"
            app:tint="@color/accent_light" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Configura el número de teléfono\ndonde recibirás las alertas SMS"
            android:textColor="@color/text_primary"
            android:textSize="15sp" />

        <!-- ═══ SECCIÓN: NÚMERO DE TELÉFONO ═══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:letterSpacing="0.06"
            android:text="NÚMERO DE ALERTA SMS"
            android:textColor="@color/accent_light"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="3dp"
            android:text="Este número recibirá un SMS cuando el módulo MT Guard detecte una situación de alerta en el vehículo."
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <!-- Campo número -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/settings_option_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+51"
                android:textColor="@color/accent_light"
                android:textSize="16sp"
                android:textStyle="bold" />

            <View
                android:layout_width="1dp"
                android:layout_height="28dp"
                android:layout_marginStart="12dp"
                android:layout_marginEnd="12dp"
                android:background="@color/divider" />

            <EditText
                android:id="@+id/etPhoneNumber"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:hint="999 999 999"
                android:inputType="phone"
                android:letterSpacing="0.06"
                android:maxLength="11"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Botón guardar -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnGuardarNumero"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="18dp"
            android:background="@drawable/panel_button_blue"
            android:letterSpacing="0.04"
            android:text="GUARDAR NÚMERO"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <!-- ═══ SEPARADOR ═══ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="28dp"
            android:background="@color/divider" />

        <!-- ═══ ESTADO GUARDADO ═══ -->
        <LinearLayout
            android:id="@+id/layoutNumeroGuardado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/settings_option_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="18dp"
            android:visibility="gone">

            <View
                android:id="@+id/dotEstado"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/status_dot_connected" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:text="Número configurado"
                android:textColor="@color/text_primary"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvNumeroGuardado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.04"
                android:textColor="@color/accent_light"
                android:textSize="14sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Nota -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:gravity="center"
            android:lineSpacingExtra="3dp"
            android:text="La app necesita el permiso de SMS para enviar alertas. Se te pedirá al momento de enviar."
            android:textColor="@color/text_hint"
            android:textSize="11sp" />

    </LinearLayout>
</ScrollView>