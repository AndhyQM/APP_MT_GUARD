<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_splash"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/screen_padding_h"
        android:paddingTop="@dimen/screen_padding_top"
        android:paddingEnd="@dimen/screen_padding_h"
        android:paddingBottom="@dimen/screen_padding_bottom">

        <!-- ═══ ENCABEZADO ═══ -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="@dimen/header_height">

            <androidx.appcompat.widget.AppCompatImageButton
                android:id="@+id/btnBack"
                android:layout_width="@dimen/header_button_size"
                android:layout_height="@dimen/header_button_size"
                android:layout_gravity="start|center_vertical"
                android:background="@android:color/transparent"
                android:contentDescription="Volver"
                android:padding="9dp"
                app:srcCompat="@drawable/ic_back_panel"
                app:tint="@color/accent_light" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:letterSpacing="0.08"
                android:text="CONFIGURAR BEACON"
                android:textColor="@color/accent_light"
                android:textSize="@dimen/title_text_size"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- ═══ SEPARADOR ═══ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="12dp"
            android:background="@color/divider" />

        <!-- ═══ SECCIÓN: MAC DEL DISPOSITIVO ═══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:letterSpacing="0.06"
            android:text="DIRECCIÓN MAC"
            android:textColor="@color/accent_light"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="3dp"
            android:text="Se configura automáticamente al conectar con un módulo MT Guard. Puedes editarla manualmente si lo necesitas."
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <!-- Campo MAC -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/settings_option_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:contentDescription="Bluetooth"
                android:src="@drawable/ic_settings_beacon"
                app:tint="@color/accent_light" />

            <EditText
                android:id="@+id/etMacAddress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:fontFamily="monospace"
                android:hint="AA:BB:CC:DD:EE:FF"
                android:inputType="textCapCharacters|textNoSuggestions"
                android:letterSpacing="0.08"
                android:maxLength="17"
                android:maxLines="1"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_hint"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Botón guardar MAC -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnGuardarMac"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/panel_button_blue"
            android:letterSpacing="0.04"
            android:text="GUARDAR MAC"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:textStyle="bold"
            app:backgroundTint="@null" />

        <!-- ═══ SEPARADOR ═══ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="26dp"
            android:background="@color/divider" />

        <!-- ═══ SECCIÓN: ESTADO DEL BEACON ═══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:letterSpacing="0.06"
            android:text="ESTADO DEL BEACON"
            android:textColor="@color/accent_light"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="3dp"
            android:text="Activa el beacon para que el módulo transmita el estado del vehículo."
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <!-- Switch beacon ON/OFF -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/settings_option_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="18dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Beacon activo"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switchBeacon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="@color/accent_light"
                app:trackTint="@color/border_input" />
        </LinearLayout>

        <!-- ═══ SEPARADOR ═══ -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="26dp"
            android:background="@color/divider" />

        <!-- ═══ SECCIÓN: DATOS EN TIEMPO REAL ═══ -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:letterSpacing="0.06"
            android:text="DATOS DEL VEHÍCULO"
            android:textColor="@color/accent_light"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:lineSpacingExtra="3dp"
            android:text="Estado reportado por el módulo en tiempo real."
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <!-- Indicador: Contacto -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:background="@drawable/settings_option_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="18dp">

            <View
                android:id="@+id/dotContacto"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/status_dot_disconnected" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:text="Contacto"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvContactoEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.04"
                android:text="CERRADO"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Indicador: Arranque -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:background="@drawable/settings_option_bg"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="18dp">

            <View
                android:id="@+id/dotArranque"
                android:layout_width="10dp"
                android:layout_height="10dp"
                android:background="@drawable/status_dot_disconnected" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:text="Arranque"
                android:textColor="@color/text_primary"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvArranqueEstado"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:letterSpacing="0.04"
                android:text="INACTIVO"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Último dato recibido -->
        <TextView
            android:id="@+id/tvUltimaActualizacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:text="Sin datos recibidos"
            android:textColor="@color/text_hint"
            android:textSize="11sp" />

    </LinearLayout>
</ScrollView>