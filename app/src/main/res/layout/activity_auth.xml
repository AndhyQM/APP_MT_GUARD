<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MT GUARD"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ingresa tu PIN"
        android:textSize="18sp"
        android:layout_marginBottom="32dp" />

    <!-- PIN -->
    <EditText
        android:id="@+id/etPin"
        android:layout_width="200dp"
        android:layout_height="52dp"
        android:hint="PIN (4 dígitos)"
        android:inputType="numberPassword"
        android:gravity="center"
        android:maxLength="4"
        android:textSize="20sp" />

    <!-- Confirmar PIN (solo al crear) -->
    <EditText
        android:id="@+id/etPinConfirm"
        android:layout_width="200dp"
        android:layout_height="52dp"
        android:hint="Confirmar PIN"
        android:inputType="numberPassword"
        android:gravity="center"
        android:maxLength="4"
        android:textSize="20sp"
        android:layout_marginTop="12dp"
        android:visibility="gone" />

    <!-- Pregunta secreta -->
    <EditText
        android:id="@+id/etPregunta"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Pregunta secreta"
        android:textSize="14sp"
        android:layout_marginTop="12dp"
        android:visibility="gone" />

    <!-- Respuesta secreta -->
    <EditText
        android:id="@+id/etRespuesta"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="Respuesta secreta"
        android:textSize="14sp"
        android:layout_marginTop="12dp"
        android:visibility="gone" />

    <Button
        android:id="@+id/btnAccion"
        android:layout_width="200dp"
        android:layout_height="48dp"
        android:text="Entrar"
        android:layout_marginTop="24dp" />

    <TextView
        android:id="@+id/tvOlvide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿Olvidaste tu PIN?"
        android:textSize="14sp"
        android:textColor="#1976D2"
        android:layout_marginTop="16dp"
        android:visibility="gone" />

</LinearLayout>