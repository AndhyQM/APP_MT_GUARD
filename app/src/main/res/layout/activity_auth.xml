<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="32dp"
    android:gravity="center"
    android:background="@color/bg_primary">

    <!-- Logo / Título -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MT GUARD"
        android:textSize="36sp"
        android:textStyle="bold"
        android:textColor="@color/accent"
        android:letterSpacing="0.15"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sistema de Seguridad Vehicular"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginBottom="40dp" />

    <!-- Subtítulo dinámico -->
    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ingresa tu PIN"
        android:textSize="18sp"
        android:textColor="@color/text_primary"
        android:layout_marginBottom="24dp" />

    <!-- PIN -->
    <EditText
        android:id="@+id/etPin"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:hint="PIN (4 dígitos)"
        android:inputType="numberPassword"
        android:gravity="center"
        android:maxLength="4"
        android:textSize="22sp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:background="@drawable/input_bg"
        android:paddingStart="16dp"
        android:paddingEnd="16dp" />

    <!-- Confirmar PIN -->
    <EditText
        android:id="@+id/etPinConfirm"
        android:layout_width="220dp"
        android:layout_height="56dp"
        android:hint="Confirmar PIN"
        android:inputType="numberPassword"
        android:gravity="center"
        android:maxLength="4"
        android:textSize="22sp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:background="@drawable/input_bg"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginTop="12dp"
        android:visibility="gone" />

    <!-- Pregunta secreta -->
    <EditText
        android:id="@+id/etPregunta"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Pregunta secreta"
        android:textSize="14sp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:background="@drawable/input_bg"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginTop="12dp"
        android:visibility="gone" />

    <!-- Respuesta secreta -->
    <EditText
        android:id="@+id/etRespuesta"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:hint="Respuesta secreta"
        android:textSize="14sp"
        android:textColor="@color/text_primary"
        android:textColorHint="@color/text_hint"
        android:background="@drawable/input_bg"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginTop="12dp"
        android:visibility="gone" />

    <!-- Botón principal -->
    <Button
        android:id="@+id/btnAccion"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:text="ENTRAR"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/bg_primary"
        android:backgroundTint="@color/accent"
        android:layout_marginTop="28dp" />

    <!-- Olvidé PIN -->
    <TextView
        android:id="@+id/tvOlvide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿Olvidaste tu PIN?"
        android:textSize="14sp"
        android:textColor="@color/accent_light"
        android:layout_marginTop="20dp"
        android:visibility="gone" />

</LinearLayout>